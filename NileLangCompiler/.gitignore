
# -----------------------------
# 1. Compiled Build Folders (The most important ones!)
# -----------------------------
# These folders contain the generated .dll and .exe files. 
# They are recreated every time you run the code.
[Bb]in/
[Oo]bj/

# -----------------------------
# 2. IDE and Editor Folders
# -----------------------------
# These hide personal editor settings, so you don't overwrite 
# your teammates' VS Code configurations in the future.
.vscode/
.vs/
*.user

# -----------------------------
# 3. Operating System Junk
# -----------------------------
# Hides hidden files created by Windows or Mac
.DS_Store
Thumbs.db